{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "workflow-ui",
  "version": "0.1.1",
  "identifier": "com.luotai.workflow-xun",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && cargo build --release --bin workFlow --no-default-features --features mcp --manifest-path src-tauri/Cargo.toml",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "workFlow UI 配置端",
        "width": 800,
        "height": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
